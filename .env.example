# 本文件只提供本地示例值，不要写入真实生产密钥。
# Profile 由启动命令、CI 或部署平台显式指定；application.yaml 不负责激活 profile。
SPRING_PROFILES_ACTIVE=dev

# Docker Compose PostgreSQL
# compose.yaml 使用这些变量创建本地 PostgreSQL 容器。
POSTGRES_DB=signal_brief
POSTGRES_PASSWORD=123456
POSTGRES_USER=celestrong
POSTGRES_PORT=5432

# Spring Datasource
# application-dev.yaml 对这些变量有本地默认值；test/prod 环境保持必填，缺失时应启动失败。
SPRING_DATASOURCE_USERNAME=celestrong
SPRING_DATASOURCE_PASSWORD=123456
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/signal_brief

# Spring Boot
# 本地应用端口。test/prod 环境通过环境变量显式提供。
SERVER_PORT=8080

# 本地测试通常通过命令行使用 -Dspring.docker.compose.enabled=false；CI 使用该环境变量关闭测试进程接管 compose.yaml。
SPRING_DOCKER_COMPOSE_ENABLED=false

# SignalBrief Feature Flags
# 内部手动触发 API，默认关闭；开启后暴露 RSS、简报生成、归档和邮件发送内部入口。
SIGNAL_BRIEF_INTERNAL_API_ENABLED=false

# OpenAPI / Swagger UI，默认关闭；开启后暴露 /internal/api-docs/internal 和 /internal/swagger-ui.html。
SIGNAL_BRIEF_OPENAPI_ENABLED=false

# RSS 定时入库，默认关闭，避免本地启动时自动访问外部 RSS 源。
SIGNAL_BRIEF_INGESTION_ENABLED=false

# RSS 入库 cron，默认每月 1 日和 16 日 06:00 执行。
SIGNAL_BRIEF_INGESTION_CRON="0 0 6 1,16 * *"

# RSS feed HTTP User-Agent。访问外部 RSS 时发送，便于对方识别调用来源。
SIGNAL_BRIEF_FEED_HTTP_USER_AGENT=signal-brief/0.0.1

# RSS feed HTTP 连接建立超时和响应读取超时。
SIGNAL_BRIEF_FEED_HTTP_CONNECT_TIMEOUT=3s
SIGNAL_BRIEF_FEED_HTTP_READ_TIMEOUT=10s

# RSS feed HTTP 总尝试次数和两次尝试之间的等待时间。
SIGNAL_BRIEF_FEED_HTTP_RETRY_MAX_ATTEMPTS=2
SIGNAL_BRIEF_FEED_HTTP_RETRY_BACKOFF=1s

# AI Summary
# OpenAI-compatible Chat Completions 摘要能力，默认关闭。
SIGNAL_BRIEF_AI_SUMMARY_ENABLED=false

# Provider base URL 按平台要求填写，可能包含版本前缀，例如 https://api.deepseek.com 或 https://api.example.com/v1。
SIGNAL_BRIEF_AI_SUMMARY_BASE_URL=

# API key 只放本地或部署环境，不能提交真实密钥。
SIGNAL_BRIEF_AI_SUMMARY_API_KEY=

# Provider 模型名称，例如 deepseek-chat、moonshot-v1-8k、qwen-plus 等。
SIGNAL_BRIEF_AI_SUMMARY_MODEL=

# AI Provider HTTP 超时。
SIGNAL_BRIEF_AI_SUMMARY_CONNECT_TIMEOUT=3s
SIGNAL_BRIEF_AI_SUMMARY_READ_TIMEOUT=30s

# 摘要生成参数。
SIGNAL_BRIEF_AI_SUMMARY_TEMPERATURE=0.2
SIGNAL_BRIEF_AI_SUMMARY_MAX_OUTPUT_TOKENS=2000

# Mail Delivery
# 邮件投递默认关闭；开启后必须配置发件人、收件人和有效 SMTP。
SIGNAL_BRIEF_MAIL_ENABLED=false
SIGNAL_BRIEF_MAIL_FROM=noreply@example.com
SIGNAL_BRIEF_MAIL_RECIPIENTS=reader@example.com
SIGNAL_BRIEF_MAIL_SUBJECT_PREFIX=SignalBrief 技术半月报

# Spring Mail 标准配置。不要提交真实 SMTP 凭据。
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
